# ================================================================================
# CONFIGURAÇÃO DE API KEYS - FLOWCASH GLOBAL
# ================================================================================
# Copie este arquivo para .env e preencha com suas chaves de API
# ================================================================================

# ================================================================================
# OPENAI - OBRIGATÓRIO
# ================================================================================
# Chave da API da OpenAI para os agentes de IA
# Obtida em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Modelo padrão para os agentes (opções: gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# ================================================================================
# CRIAÇÃO DE IMAGENS E VÍDEOS (OPCIONAL)
# ================================================================================
# Chave para geração de imagens com DALL-E ou similar
OPENAI_API_KEY_DALLE=sk-your-openai-api-key-here

# ================================================================================
# HUGGING FACE (OPCIONAL)
# ================================================================================
# Token para modelos open-source do Hugging Face
# Obtido em: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf-your-huggingface-token-here

# ================================================================================
# SERVIÇOS EXTERNOS (OPCIONAL)
# ================================================================================

# HubSpot CRM
HUBSPOT_API_KEY=your-hubspot-api-key

# SendGrid (E-mail marketing)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret

# Meta Ads (Facebook/Instagram)
META_ADS_ACCESS_TOKEN=your-meta-access-token
META_ADS_AD_ACCOUNT_ID=act_xxxxxxxxxxx

# LinkedIn Ads
LINKEDIN_ADS_CLIENT_ID=your-client-id
LINKEDIN_ADS_CLIENT_SECRET=your-client-secret

# ================================================================================
# BANCO DE DADOS (OPCIONAL)
# ================================================================================

# PostgreSQL (se usar banco próprio)
DATABASE_URL=postgresql://user:password@localhost:5432/flowcash

# ================================================================================
# ARMAZENAMENTO (OPCIONAL)
# ================================================================================

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=flowcash-assets

# ================================================================================
# CONFIGURAÇÕES DE AMBIENTE
# ================================================================================

# Ambiente (development, staging, production)
ENVIRONMENT=development

# Nível de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ================================================================================
# NOTAS
# ================================================================================
# 1. O arquivo .env NUNCA deve ser commitado no GitHub
# 2. Adicione .env ao seu .gitignore
# 3. Para produção, use variáveis de ambiente do sistema ou serviço de secrets
# ================================================================================
